     "name": "stdout",
     "output_type": "stream",
     "text": [
      "10\n"
     ]
    }
   ],
   "source": [
    "s=\"abcdbcacdsaefghib\"\n",
    "left=0\n",
    "result=set()\n",
    "longest=0\n",
    "for right in range(len(s)):\n",
    "    while s[right] in result:\n",
    "        result.remove(s[left])\n",
    "        left+=1\n",
    "    result.add(s[right])\n",
    "    longest=max(longest,right-left+1)\n",
    "print(longest)"
   ]
  }
